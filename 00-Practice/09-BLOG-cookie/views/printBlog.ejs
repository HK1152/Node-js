<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blogs</title>
    <style>
        :root {
            --bg: #f5efe6;
            --panel: rgba(255, 255, 255, 0.88);
            --panel-strong: #ffffff;
            --text: #1f2937;
            --muted: #6b7280;
            --accent: #c05a1a;
            --accent-soft: rgba(192, 90, 26, 0.12);
            --line: rgba(31, 41, 55, 0.1);
            --shadow: 0 18px 48px rgba(31, 41, 55, 0.12);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at top left, rgba(192, 90, 26, 0.16), transparent 25%),
                radial-gradient(circle at top right, rgba(14, 165, 233, 0.14), transparent 20%),
                linear-gradient(180deg, #fbf6ef 0%, var(--bg) 100%);
        }

        .page {
            width: min(1180px, calc(100% - 32px));
            margin: 0 auto;
            padding: 40px 0 60px;
        }

        .hero {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 24px;
            align-items: stretch;
            margin-bottom: 30px;
        }

        .hero-main,
        .hero-side {
            background: var(--panel);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 28px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(10px);
        }

        .hero-main {
            padding: 34px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            border-radius: 999px;
            background: var(--accent-soft);
            color: var(--accent);
            font-size: 0.92rem;
            font-weight: 700;
        }

        h1 {
            margin: 18px 0 14px;
            font-size: clamp(2.2rem, 4vw, 3.8rem);
            line-height: 1.02;
        }

        .hero-main p {
            margin: 0;
            max-width: 42rem;
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.75;
        }

        .hero-side {
            padding: 28px;
            display: grid;
            gap: 18px;
            align-content: center;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 248, 242, 0.92));
        }

        .stat-value {
            font-size: 2.4rem;
            font-weight: 800;
        }

        .stat-label {
            color: var(--muted);
            line-height: 1.6;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 22px;
        }

        .card {
            position: relative;
            overflow: hidden;
            background: var(--panel-strong);
            border: 1px solid var(--line);
            border-radius: 24px;
            padding: 24px;
            box-shadow: var(--shadow);
        }

        .card::before {
            content: "";
            position: absolute;
            inset: 0 auto auto 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, #c05a1a, #ef8a45, #30a6d8);
        }

        .meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .author {
            display: inline-flex;
            align-items: center;
            padding: 7px 12px;
            border-radius: 999px;
            background: #f8f3ed;
            color: #6a3b1f;
            font-weight: 700;
        }

        .card h2 {
            margin: 0 0 14px;
            font-size: 1.4rem;
            line-height: 1.3;
        }

        .card p {
            margin: 0;
            color: #4b5563;
            line-height: 1.75;
        }

        .empty {
            padding: 42px 28px;
            text-align: center;
            background: var(--panel);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 28px;
            box-shadow: var(--shadow);
        }

        .empty h2 {
            margin: 0 0 10px;
            font-size: 1.8rem;
        }

        .empty p {
            margin: 0;
            color: var(--muted);
            line-height: 1.7;
        }

        @media (max-width: 820px) {
            .hero {
                grid-template-columns: 1fr;
            }

            .page {
                width: min(100% - 20px, 1180px);
                padding-top: 20px;
            }

            .hero-main,
            .hero-side,
            .card,
            .empty {
                border-radius: 22px;
            }
        }
    </style>
</head>
<body>
    <% const blogs = Array.isArray(data) ? data : []; %>
    <main class="page">
        <section class="hero">
            <div class="hero-main">
                <span class="badge">Blog Collection</span>
                <h1>Stories, notes, and ideas in one polished feed.</h1>
                <p>
                    Browse all published blog entries with a cleaner reading layout, clear author details,
                    and a card-based design that makes each post easier to scan.
                </p>
            </div>

            <aside class="hero-side">
                <div class="stat-value"><%= blogs.length %></div>
                <div class="stat-label">
                    <strong>Total blogs available</strong><br>
                    <%= message || "Your blog posts are listed below." %>
                </div>
            </aside>
        </section>

        <% if (blogs.length > 0) { %>
            <section class="grid">
                <% blogs.forEach((blog) => { %>
                    <article class="card">
                        <div class="meta">
                            <span class="author"><%= blog.author %></span>
                            <span>
                                <%= new Date(blog.createdAt).toLocaleDateString("en-IN", {
                                    day: "2-digit",
                                    month: "short",
                                    year: "numeric"
                                }) %>
                            </span>
                        </div>
                        <h2><%= blog.title %></h2>
                        <p><%= blog.content %></p>
                    </article>
                <% }) %>
            </section>
        <% } else { %>
            <section class="empty">
                <h2>No blogs yet</h2>
                <p>
                    Your blog page is ready. Add some posts to see them appear here with the new UI.
                </p>
            </section>
        <% } %>
    </main>
</body>
</html>
