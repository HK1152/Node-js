<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        :root {
            --bg-start: #f9efe3;
            --bg-end: #d8e6f2;
            --card: rgba(255, 255, 255, 0.9);
            --text: #1f2937;
            --muted: #6b7280;
            --accent: #c46a2a;
            --accent-dark: #9f4f17;
            --border: rgba(31, 41, 55, 0.12);
            --shadow: 0 24px 60px rgba(31, 41, 55, 0.18);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text);
            background: linear-gradient(145deg, var(--bg-start), var(--bg-end));
            display: grid;
            place-items: center;
            padding: 24px;
        }

        .signin-shell {
            width: 100%;
            max-width: 980px;
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: var(--shadow);
            backdrop-filter: blur(12px);
        }

        .signin-copy {
            padding: 56px;
            background:
                radial-gradient(circle at top left, rgba(196, 106, 42, 0.22), transparent 32%),
                radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.18), transparent 28%);
        }

        .eyebrow {
            display: inline-block;
            padding: 8px 14px;
            border-radius: 999px;
            background: rgba(196, 106, 42, 0.12);
            color: var(--accent-dark);
            font-size: 0.9rem;
            font-weight: 600;
            letter-spacing: 0.03em;
        }

        h1 {
            margin: 22px 0 14px;
            font-size: clamp(2.4rem, 5vw, 4rem);
            line-height: 1.02;
        }

        .lead {
            margin: 0;
            max-width: 28rem;
            color: var(--muted);
            font-size: 1.02rem;
            line-height: 1.7;
        }

        .highlights {
            margin-top: 34px;
            display: grid;
            gap: 14px;
        }

        .highlight {
            padding: 16px 18px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.55);
            border: 1px solid rgba(255, 255, 255, 0.75);
        }

        .highlight strong {
            display: block;
            margin-bottom: 6px;
        }

        .signin-card {
            padding: 56px 40px;
            background: rgba(255, 255, 255, 0.76);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .signin-card h2 {
            margin: 0 0 10px;
            font-size: 1.8rem;
        }

        .signin-card p {
            margin: 0 0 28px;
            color: var(--muted);
            line-height: 1.6;
        }

        form {
            display: grid;
            gap: 18px;
        }

        label {
            display: grid;
            gap: 8px;
            font-size: 0.95rem;
            font-weight: 600;
        }

        input {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid var(--border);
            border-radius: 14px;
            outline: none;
            font: inherit;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            background: rgba(255, 255, 255, 0.92);
        }

        input:focus {
            border-color: rgba(196, 106, 42, 0.7);
            box-shadow: 0 0 0 4px rgba(196, 106, 42, 0.14);
        }

        .form-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            color: var(--muted);
            font-size: 0.92rem;
        }

        .form-row a,
        .signup-text a {
            color: var(--accent-dark);
            text-decoration: none;
            font-weight: 600;
        }

        button {
            border: none;
            border-radius: 14px;
            padding: 15px 18px;
            font: inherit;
            font-weight: 700;
            color: #fff;
            background: linear-gradient(135deg, var(--accent), var(--accent-dark));
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            box-shadow: 0 18px 30px rgba(159, 79, 23, 0.22);
        }

        button:hover {
            transform: translateY(-1px);
        }

        .signup-text {
            margin-top: 20px;
            text-align: center;
            color: var(--muted);
        }

        @media (max-width: 820px) {
            .signin-shell {
                grid-template-columns: 1fr;
            }

            .signin-copy,
            .signin-card {
                padding: 32px 24px;
            }
        }
    </style>
</head>
<body>
    <main class="signin-shell">
        <section class="signin-copy">
            <span class="eyebrow">Welcome back</span>
            <h1>Sign in and keep your stories moving.</h1>
            <p class="lead">
                Access your blog dashboard, manage drafts, and publish ideas with a simple, focused sign-in experience.
            </p>

            <div class="highlights">
                <div class="highlight">
                    <strong>Write without friction</strong>
                    Pick up where you left off and return straight to your latest posts.
                </div>
                <div class="highlight">
                    <strong>Stay organized</strong>
                    Keep drafts, published posts, and updates in one familiar workflow.
                </div>
            </div>
        </section>

        <section class="signin-card">
            <h2>Sign In</h2>
            <p>Enter your email and password to continue to your account.</p>

            <% if (typeof error !== 'undefined' && error) { %>
                <div style="background: #fee2e2; color: #b91c1c; padding: 12px; border-radius: 12px; margin-bottom: 20px; font-size: 0.9rem; font-weight: 600; text-align: center; border: 1px solid #fecaca;">
                    <%= error %>
                </div>
            <% } %>

            <form action="/signin" method="post">
                <label for="email">
                    Email Address
                    <input type="email" id="email" name="email" placeholder="you@example.com" required>
                </label>

                <label for="password">
                    Password
                    <input type="password" id="password" name="password" placeholder="Enter your password" required>
                </label>

                <div class="form-row">
                    <span>Keep your session secure.</span>
                   
                </div>

                <button type="submit">Sign In</button>
            </form>

        </section>
    </main>
</body>
</html>
