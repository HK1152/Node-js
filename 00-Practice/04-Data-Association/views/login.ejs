<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>create</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
   <div class="w-full h-screen bg-zinc-900 flex items-center justify-center flex-col gap-4">
    <h1 class="text-white text-2xl font-bold">Login</h1>
    <form action="/login" method="post" class="bg-white p-6 rounded shadow-md w-96">
        <input type="email" name="email" placeholder="Email" class="w-full mb-4 p-2 border border-gray-300 rounded">
        <input type="password" name="password" placeholder="Password" class="w-full mb-4 p-2 border border-gray-300 rounded">
        <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded hover:bg-blue-600">Login</button>
    </form>
    </div>
</body>
</html>