<!DOCTYPE html>
<html lang="en">

<head>
   <meta charset="UTF-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <title>Nexus — Profile</title>
   <meta name="description" content="Your Nexus profile dashboard." />
   <link rel="stylesheet" href="/style.css" />
</head>

<body>

   <!-- Background -->
   <div class="bg-scene">
      <div class="bg-orb bg-orb--1"></div>
      <div class="bg-orb bg-orb--2"></div>
      <div class="bg-orb bg-orb--3"></div>
   </div>
   <div class="bg-particles" id="particles"></div>

   <!-- Profile Page -->
   <div class="profile-page">

      <!-- Top Bar -->
      <div class="top-bar">
         <div class="top-bar-brand">
            <div class="top-bar-logo">N</div>
            Nexus
         </div>
         <div class="top-bar-actions">
            <a href="/logout" class="btn btn-danger" id="logoutBtn">⏻ Logout</a>
         </div>
      </div>

      <!-- Profile Header -->
      <div class="profile-card">
         <div class="avatar" style="position:relative;">
            <%= user.name.charAt(0).toUpperCase() %>
               <div class="avatar-online"></div>
         </div>
         <div>
            <h2 class="profile-name gradient-text">Hey, <%= user.name %> 👋</h2>
            <div class="profile-username">@<%= user.username %>
            </div>
            <div class="profile-meta">
               <span class="meta-tag">✉ <%= user.email %></span>
               <span class="meta-tag">🎂 Age <%= user.age %></span>
               <span class="meta-tag">📝 <%= user.posts.length %> Posts</span>
            </div>
         </div>
      </div>

      <!-- Stats -->
      <div class="stats-row">
         <div class="stat-box">
            <div class="stat-num" id="totalPosts">
               <%= user.posts.length %>
            </div>
            <div class="stat-label">Total Posts</div>
         </div>
         <div class="stat-box">
            <div class="stat-num" id="totalLikes">
               <%= user.posts.reduce((sum, p)=> sum + p.likes.length, 0) %>
            </div>
            <div class="stat-label">Total Likes</div>
         </div>
         <div class="stat-box">
            <div class="stat-num" style="color: var(--success);">●</div>
            <div class="stat-label">Active Now</div>
         </div>
      </div>

      <!-- Create Post -->
      <div class="create-box">
         <h3>✍ What's on your mind?</h3>
         <form action="/post" method="post" id="postForm">
            <div class="form-group" style="margin-bottom:1rem;">
               <textarea id="postContent" name="content" placeholder="Share something with the world…"
                  class="form-textarea" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary" id="postBtn" style="max-width:220px;">
               <span class="btn-text">Publish Post →</span>
            </button>
         </form>
      </div>

      <!-- Posts -->
      <div>
         <h3 class="posts-title">📋 Your Posts</h3>

         <% if (user.posts.length===0) { %>
            <div class="empty-state"
               style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-xl); backdrop-filter:blur(20px);">
               <div class="empty-icon">🌌</div>
               <h3 style="font-family:'Space Grotesk',sans-serif; color:var(--text-light);">No posts yet</h3>
               <p style="color:var(--text-muted); margin-top:0.5rem;">Share your first thought with the world!</p>
            </div>
            <% } else { %>
               <div class="posts-grid">
                  <% user.posts.slice().reverse().forEach(function(post) { %>
                     <div class="post-card">
                        <div class="post-head">
                           <div class="post-av">
                              <%= user.name.charAt(0).toUpperCase() %>
                           </div>
                           <div>
                              <div class="post-user">@<%= user.username %>
                              </div>
                              <div class="post-date">
                                 <%= new Date(post.date).toLocaleDateString('en-IN', { day:'2-digit', month:'short',
                                    year:'numeric' }) %>
                              </div>
                           </div>
                        </div>

                        <p class="post-body">
                           <%= post.content %>
                        </p>

                        <div class="post-foot">
                           <div class="post-likes">
                              ❤ <%= post.likes.length %>
                                 <%= post.likes.length===1 ? 'like' : 'likes' %>
                           </div>
                           <div class="post-btns">
                              <a href="/post/<%= post._id %>" class="btn btn-pill">
                                 <%= post.likes.indexOf(user._id.toString()) !==-1 ? '💔 Unlike' : '❤ Like' %>
                              </a>
                              <a href="/edit/<%= post._id %>" class="btn btn-pill">✎ Edit</a>
                           </div>
                        </div>
                     </div>
                     <% }) %>
               </div>
               <% } %>
      </div>

   </div>

   <script>
      const pc = document.getElementById('particles');
      for (let i = 0; i < 14; i++) {
         const d = document.createElement('div');
         d.classList.add('dot');
         const s = Math.random() * 3 + 1.5;
         d.style.cssText = `width:${s}px;height:${s}px;left:${Math.random() * 100}%;animation-duration:${Math.random() * 20 + 12}s;animation-delay:-${Math.random() * 25}s;opacity:${Math.random() * 0.4 + 0.1};`;
         pc.appendChild(d);
      }

      document.getElementById('postForm').addEventListener('submit', function () {
         const b = document.getElementById('postBtn');
         b.querySelector('.btn-text').textContent = 'Publishing…';
         b.disabled = true;
      });

      function animateCounter(el) {
         const t = parseInt(el.textContent, 10);
         if (isNaN(t) || t === 0) return;
         let c = 0;
         const step = Math.ceil(t / 25);
         const timer = setInterval(() => {
            c += step;
            if (c >= t) { el.textContent = t; clearInterval(timer); }
            else el.textContent = c;
         }, 45);
      }
      document.querySelectorAll('.stat-num').forEach(el => {
         if (!isNaN(parseInt(el.textContent))) animateCounter(el);
      });
   </script>
</body>

</html>