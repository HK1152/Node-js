<!DOCTYPE html>
<html lang="en">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Profile</title>
   <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
   <div class="w-full min-h-screen bg-zinc-900 text-white p-6">

      <div class="flex items-center justify-start gap-4 mb-7">
         <a href="/logout" class="bg-red-500 rounded-md px-3 py-2">logout</a>
      </div>
      <h1 class="text-3xl  font-bold">hello,<%= user.name %>😁</h1>
      <h5>You can create a new post.</h5>
      <form action="/post" method="post" class="w-full max-w-md flex flex-col gap-2">
         <textarea name="content" id="" cols="10" rows="5" placeholder="What's on your mind?"
            class="w-full p-2 rounded-md bg-zinc-800 text-white mt-2 outline-"></textarea>
         <button class="bg-blue-500 px-4 py-2 rounded-md mt-2">Create Post</button>
      </form>
      <div class="posts  mt-10">
         <h3 class="text-zinc-400">Your posts</h3>
         <div class="flex flex-col gap-4 mt-4">
            <% user.posts.reverse().forEach(post=> { %>
               <div class="post w-1/3 bg-zinc-800 p-5 border-2 border-zinc-800 rounded-md mt-3">
                  <div class="flex justify-start items-center gap-3">
                     <h4 class="text-xl font-bold text-blue-500">@<%= user.username %>
                     </h4>
                     <span class="text-zinc-500 text-sm">
                        <%= post.date.toLocaleString() %>
                     </span>
                  </div>
                  <p class="mt-2 text-sm tracking-tight mb-2">
                     <%= post.content %>
                  </p>
                  <small class="text-zinc-500 mt-5">
                     <%= post.likes.length %>
                        <%= post.likes.length===-1 ? "like" : "likes" %>
                  </small>
                  <div class="btns flex items-center gap-2 ">
                     <a href="/post/<%= post._id %>" class="text-blue-500">
                        <%= post.likes.indexOf(user._id) !==-1 ? 'Unlike' : 'Like' %>
                     </a>
                     <a href="/edit/<%= post._id %>" class="text-zinc-600">edit</a>
                  </div>
               </div>
               <% }) %>
         </div>
      </div>

</body>

</html>