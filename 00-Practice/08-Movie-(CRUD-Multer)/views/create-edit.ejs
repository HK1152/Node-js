<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>S.H.I.E.L.D. Data Entry</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --marvel-red: #E23636;
            --marvel-dark: #151515;
            --marvel-panel: #222;
            --marvel-light: #fefefe;
            --marvel-blue: #00e5ff;
        }
        body { 
            font-family: 'Roboto', sans-serif; 
            margin: 0; 
            background-color: #0a0a0a; 
            color: var(--marvel-light);
            background-image: 
                radial-gradient(circle at 100% 0%, rgba(0, 229, 255, 0.1) 0%, transparent 40%),
                radial-gradient(circle at 0% 100%, rgba(226, 54, 54, 0.1) 0%, transparent 40%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-bottom: 50px;
        }
        header {
            width: 100%;
            background-color: var(--marvel-dark);
            padding: 15px 0;
            text-align: center;
            border-bottom: 2px solid var(--marvel-red);
            margin-bottom: 40px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }
        h1.logo {
            font-family: 'Bebas Neue', cursive; 
            font-size: 2.5rem;
            margin: 0;
            letter-spacing: 4px;
            color: var(--marvel-light);
        }
        .logo span {
            background-color: var(--marvel-red);
            padding: 0 5px;
            color: white;
            border-radius: 2px;
        }
        .form-container {
            background: var(--marvel-panel);
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 0 1px #333;
            width: 100%;
            max-width: 500px;
            position: relative;
            overflow: hidden;
            box-sizing: border-box;
        }
        .form-container::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--marvel-red), var(--marvel-blue));
        }
        h2 {
            font-family: 'Bebas Neue', cursive;
            color: var(--marvel-blue);
            font-size: 2rem;
            margin-top: 0;
            letter-spacing: 2px;
            border-bottom: 1px solid #333;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label { 
            display: block; 
            margin-bottom: 8px; 
            color: #aaa;
            font-size: 0.9rem;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        input[type="text"], 
        input[type="number"], 
        input[type="file"] { 
            width: 100%; 
            padding: 12px; 
            background: #111;
            border: 1px solid #333;
            color: white;
            border-radius: 4px;
            box-sizing: border-box;
            font-family: 'Roboto', sans-serif;
            transition: border-color 0.3s, box-shadow 0.3s;
        }
        input:focus {
            outline: none;
            border-color: var(--marvel-blue);
            box-shadow: 0 0 8px rgba(0, 229, 255, 0.3);
        }
        input[type="file"] {
            padding: 9px;
            color: #aaa;
        }
        input[type="file"]::file-selector-button {
            background: var(--marvel-dark);
            border: 1px solid #444;
            color: white;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            margin-right: 15px;
            transition: background 0.3s;
        }
        input[type="file"]::file-selector-button:hover {
            background: #333;
        }
        button { 
            width: 100%;
            margin-top: 10px; 
            padding: 15px; 
            background: var(--marvel-red); 
            color: white; 
            border: none; 
            border-radius: 4px;
            cursor: pointer; 
            font-family: 'Bebas Neue', cursive;
            font-size: 1.5rem;
            letter-spacing: 2px;
            transition: background 0.3s, transform 0.1s;
        }
        button:hover { 
            background: #c22020; 
        }
        button:active {
            transform: scale(0.98);
        }
        .message { 
            padding: 15px; 
            margin-bottom: 25px; 
            border-radius: 4px; 
            font-weight: bold;
            text-align: center;
        }
        .success { 
            background-color: rgba(0, 229, 255, 0.1); 
            color: var(--marvel-blue); 
            border: 1px solid var(--marvel-blue); 
        }
        .error { 
            background-color: rgba(226, 54, 54, 0.1); 
            color: var(--marvel-red); 
            border: 1px solid var(--marvel-red); 
        }
        .back-link {
            display: inline-block;
            margin-top: 25px;
            color: #aaa;
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s;
            font-weight: bold;
        }
        .back-link:hover {
            color: white;
            text-shadow: 0 0 8px rgba(255,255,255,0.5);
        }
    </style>
</head>
<body>
    <header>
        <h1 class="logo"><span>MCU</span> DATABASE</h1>
    </header>

    <div class="form-container">
        <h2><%= poster ? 'UPDATE S.H.I.E.L.D. RECORD' : 'S.H.I.E.L.D. SECURE UPLOAD' %></h2>

        <% if (typeof message !== 'undefined') { %>
            <div class="message success"><%= message %></div>
        <% } %>

        <% if (typeof error !== 'undefined') { %>
            <div class="message error"><%= error %></div>
        <% } %>

        <form action="<%= poster ? '/update/' + poster._id : '/create' %>" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="title">Designation (Movie Title)</label>
                <input type="text" id="title" name="title" value="<%= poster ? poster.title : '' %>" placeholder="e.g. Iron Man" required>
            </div>

            <div class="form-group">
                <label for="director">Lead Agent (Director)</label>
                <input type="text" id="director" name="director" value="<%= poster ? poster.director : '' %>" placeholder="e.g. Jon Favreau" required>
            </div>

            <div class="form-group">
                <label for="releaseYear">Year of Origin</label>
                <input type="number" id="releaseYear" name="releaseYear" value="<%= poster ? poster.releaseYear : '' %>" placeholder="e.g. 2008" required>
            </div>

            <div class="form-group">
                <label for="genre">Classification (Genre)</label>
                <input type="text" id="genre" name="genre" value="<%= poster ? poster.genre : '' %>" placeholder="e.g. Action, Sci-Fi" required>
            </div>

            <div class="form-group">
                <label for="posterImage">Visual Asset (Poster) <%= poster ? '(Leave empty to keep current)' : '' %></label>
                <input type="file" id="posterImage" name="posterImage" accept="image/*" <%= poster ? '' : 'required' %>>
            </div>

            <button type="submit"><%= poster ? 'UPDATE DATA' : 'TRANSMIT DATA' %></button>
        </form>
    </div>
    
    <a href="/" class="back-link">◄ RETURN TO ARCHIVES</a>
</body>
</html>