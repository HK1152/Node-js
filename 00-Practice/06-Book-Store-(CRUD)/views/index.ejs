<%- include('header') %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Featured Books</h1>
            <p class="text-gray-500 mt-1">Discover your next great read.</p>
        </div>
        <a href="/add" class="inline-flex justify-center items-center bg-gray-900 hover:bg-gray-800 text-white font-semibold py-2.5 px-6 rounded-sm transition duration-200">
            Add New Book
        </a>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-12">
            <% books?.forEach(book => { %>
                <div class="flex flex-col group">
                    <div class="bg-[#f4f5f7] w-full aspect-[3/4] flex items-center justify-center p-8 sm:p-10 relative overflow-hidden">
                        <img src="<%= book.img %>" alt="<%= book.title %>" class="w-full h-full object-cover shadow-[0_15px_35px_rgba(0,0,0,0.25)] group-hover:scale-105 transition-transform duration-500 ease-out">
                        
                        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center gap-3 backdrop-blur-sm">
                            <a href="/edit/<%= book._id %>" class="w-28 text-center bg-white text-gray-900 px-4 py-2 rounded-sm shadow hover:bg-gray-100 font-semibold text-sm transition">Edit Book</a>
                            <a href="/delete/<%= book._id %>" class="w-28 text-center bg-red-600 text-white px-4 py-2 rounded-sm shadow hover:bg-red-700 font-semibold text-sm transition" onclick="return confirm('Are you sure you want to delete this book?')">Delete</a>
                        </div>
                    </div>
                    <div class="text-center pt-5 bg-white">
                        <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">
                            <%= book.author || 'Science' %>
                        </p>
                        <h3 class="text-lg font-bold text-gray-900 mb-1 leading-snug">
                            <%= book.title %>
                        </h3>
                        <p class="text-red-600 font-extrabold text-base">
                            <%= book.price %> Rs.
                            <span class="text-sm font-semibold text-gray-300 line-through ml-1">
                                <% const oldPrice = parseFloat(book.price) ? parseFloat(book.price) + 23 : 45; %>
                                <%= oldPrice.toFixed(0) %> Rs.
                            </span>
                        </p>
                    </div>
                </div>
            <% }) %>
            
            <% if (!books || books.length === 0) { %>
                <div class="col-span-full py-20 flex flex-col items-center justify-center text-center bg-gray-50 rounded-sm">
                    <svg class="w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                    <h3 class="text-xl font-bold text-gray-900">No books found</h3>
                    <p class="text-gray-500 mt-2">Get started by adding a new book to your store.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>