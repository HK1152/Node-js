<%- include('header') %>

    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20 mt-8">
        <div class="bg-white p-8 sm:p-12 rounded-lg shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-gray-100">
            <h2 class="text-3xl font-extrabold text-gray-900 mb-8 tracking-tight">Add New Book</h2>
            <form action="/add" method="post" class="space-y-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Image URL</label>
                    <input type="text" name="img" placeholder="https://example.com/image.jpg" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent focus:bg-white transition" required>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Title</label>
                    <input type="text" name="title" placeholder="e.g. The Great Gatsby" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent focus:bg-white transition" required>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Author</label>
                    <input type="text" name="author" placeholder="e.g. F. Scott Fitzgerald" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent focus:bg-white transition" required>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Price (Rs.)</label>
                    <input type="text" name="price" placeholder="e.g. 29.99" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent focus:bg-white transition" required>
                </div>
                <div class="pt-4">
                    <button type="submit" class="w-full bg-gray-900 hover:bg-black text-white font-bold py-4 px-4 rounded-md transition duration-200 shadow-xl shadow-gray-200">
                        Add Book to Store
                    </button>
                    <div class="text-center mt-4">
                        <a href="/" class="text-sm font-medium text-gray-500 hover:text-red-600 transition">Cancel</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

</body>
</html>