<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart - Scatch Premium</title>
    <%- include('./partials/theme-head') %>
</head>

<body class="premium-shell min-h-screen font-sans antialiased">
    <%- include('./partials/header') %>
    
    <% if (typeof success !=='undefined' && success && success.length> 0) { %>
        <div class="fixed left-1/2 top-24 z-50 -translate-x-1/2 rounded border border-emerald-200 bg-emerald-50 px-6 py-3 text-sm font-semibold text-emerald-700 shadow-lg">
            <%= success %>
        </div>
    <% } %>

    <% if (typeof error !=='undefined' && error && error.length> 0) { %>
        <div class="fixed left-1/2 top-24 z-50 -translate-x-1/2 rounded border border-red-200 bg-red-50 px-6 py-3 text-sm font-semibold text-red-600 shadow-lg">
            <%= error %>
        </div>
    <% } %>

    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-10">
        <section class="premium-card mb-8 p-8 sm:p-10">
            <p class="premium-muted mb-3">Shopping Bag</p>
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <h1 class="premium-title">Your premium cart, ready for checkout.</h1>
                    <p class="mt-4 max-w-2xl text-base leading-7 text-stone-600">Review your selected pieces, see your savings clearly, and move into checkout with a cleaner high-end experience.</p>
                </div>
                <div class="rounded-[1.5rem] bg-stone-950 px-6 py-5 text-white">
                    <p class="text-xs uppercase tracking-[0.25em] text-stone-400">Items</p>
                    <p class="mt-2 text-3xl font-bold"><%= user && user.cart ? user.cart.length : 0 %></p>
                </div>
            </div>
        </section>

        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
            <section class="space-y-6">
                <% if (cartItems && cartItems.length > 0) { %>
                    <% cartItems.forEach((item)=> { %>
                        <article class="premium-card overflow-x-hidden p-3">
                            <div class="flex flex-col gap-0 lg:flex-row">
                                <div class="flex min-h-64 items-center justify-center rounded-[1.75rem] p-8 lg:w-[36%]" style="background-color: <%= item.product.bgcolor %>">
                                    <img class="h-40 object-contain" src="data:image/jpeg;base64, <%= item.product.image.toString('base64') %>" alt="<%= item.product.name %>">
                                </div>
                                <div class="flex flex-1 flex-col justify-between p-6" style="background-color: <%= item.product.panelcolor %>; color: <%= item.product.textcolor %>">
                                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                                        <div>
                                            <p class="text-xs uppercase tracking-[0.24em] opacity-60">Selected Piece</p>
                                            <h3 class="mt-3 text-3xl font-bold"><%= item.product.name %></h3>
                                            <h2 class="mt-2 text-xl font-medium">₹ <%= item.product.price %></h2>
                                        </div>
                                        <div class="rounded-full bg-white/20 px-4 py-2 text-xs font-semibold">Premium choice</div>
                                    </div>

                                    <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                                        <div class="flex items-center gap-4">
                                            <div class="flex items-center gap-4 rounded-full bg-white/20 px-3 py-2">
                                                <a href="/decrease-from-cart/<%= item.product._id %>" class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-stone-800 shadow-sm transition-colors hover:bg-stone-100">
                                                    <i class="ri-subtract-line"></i>
                                                </a>
                                                <span class="font-medium"><%= item.quantity %></span>
                                                <a href="/add-to-cart/<%= item.product._id %>" class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-stone-800 shadow-sm transition-colors hover:bg-stone-100">
                                                    <i class="ri-add-line"></i>
                                                </a>
                                            </div>
                                            <a href="/remove-from-cart/<%= item.product._id %>" class="flex h-11 w-11 items-center justify-center rounded-full bg-red-500/10 text-red-500 transition-colors hover:bg-red-500 hover:text-white" title="Remove from cart">
                                                <i class="ri-delete-bin-line text-lg"></i>
                                            </a>
                                        </div>
                                        <div class="text-lg font-bold">Net Total: ₹ <%= item.product.price * item.quantity %></div>
                                    </div>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                <% } else { %>
                    <div class="premium-card flex min-h-[420px] flex-col items-center justify-center p-12 text-center">
                        <div class="flex h-20 w-20 items-center justify-center rounded-full bg-stone-950 text-white">
                            <i class="ri-shopping-cart-2-line text-3xl"></i>
                        </div>
                        <h3 class="mt-6 font-display text-4xl font-semibold text-stone-900">Your cart is empty</h3>
                        <p class="mt-3 max-w-md text-stone-500">Looks like you have not added anything yet. Explore the latest premium collection and find your next signature piece.</p>
                        <a href="/shop" class="premium-btn mt-8">Continue Shopping</a>
                    </div>
                <% } %>
            </section>

            <aside>
                <% if (user && user.cart && user.cart.length> 0) { %>
                    <div class="premium-card sticky top-28 p-8">
                        <p class="premium-muted mb-3">Order Summary</p>
                        <h3 class="font-display text-4xl font-semibold text-stone-900">A refined finish.</h3>

                        <div class="mt-8 space-y-4 text-sm text-stone-600">
                            <div class="flex justify-between rounded-2xl bg-white/80 px-4 py-3">
                                <span>Total MRP</span>
                                <span class="font-semibold text-stone-900">₹ <%= totalMRP || 0 %></span>
                            </div>
                            <div class="flex justify-between rounded-2xl bg-emerald-50 px-4 py-3">
                                <span>Discount on MRP</span>
                                <span class="font-semibold text-emerald-700">-₹ <%= totalDiscount || 0 %></span>
                            </div>
                            <div class="flex justify-between rounded-2xl bg-white/80 px-4 py-3">
                                <span>Platform Fee</span>
                                <span class="font-semibold text-stone-900">₹ 20</span>
                            </div>
                            <div class="flex justify-between rounded-2xl bg-white/80 px-4 py-3">
                                <span>Shipping Fee</span>
                                <span class="font-semibold text-primary">FREE</span>
                            </div>
                        </div>

                        <div class="mt-8 rounded-[1.75rem] bg-stone-950 p-6 text-white">
                            <div class="flex items-center justify-between">
                                <span class="text-sm uppercase tracking-[0.24em] text-stone-400">Total Amount</span>
                                <span class="text-3xl font-bold">₹ <%= bill %></span>
                            </div>
                        </div>

                        <button class="premium-btn mt-8 w-full !justify-center !py-4">
                            Proceed to Checkout
                        </button>
                    </div>
                <% } %>
            </aside>
        </div>
    </main>
    <%- include('./partials/footer') %>
</body>

</html>
