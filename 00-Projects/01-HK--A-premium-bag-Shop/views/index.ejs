<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>hk - Sign Up / Log In</title>
    <%- include('./partials/theme-head') %>
</head>

<body class="flex flex-col min-h-screen">
    <%- include('./partials/header') %>

    <% if(error && error.length> 0){ %>
        <div class="fixed left-1/2 top-24 z-50 -translate-x-1/2 rounded border border-red-200 bg-red-50 px-6 py-3 text-sm font-semibold text-red-600 shadow-lg">
            <%= error %>
        </div>
    <% } %>

    <main class="flex-grow flex items-center justify-center pt-10 pb-20">
        <div class="max-w-7xl mx-auto w-full flex flex-col lg:flex-row items-center gap-10 lg:gap-20">
            
            <!-- Left Side Image -->
            <div class="hidden lg:flex w-full lg:w-1/2 bg-[#CBE4E8] rounded-r rounded-l-none h-[600px] items-center justify-center relative overflow-hidden">
                <img src="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?q=80&w=1000&auto=format&fit=crop" class="w-full h-full object-cover mix-blend-multiply opacity-80" alt="Shopping cart">
            </div>

            <!-- Right Side Forms -->
            <div class="w-full lg:w-1/2 px-4 sm:px-10 lg:px-0 max-w-md">
                
                <!-- Register Section -->
                <div id="register-section" class="<%= (typeof showLogin !== 'undefined' && showLogin) ? 'hidden' : 'block' %> transition-all duration-300">
                    <h2 class="text-3xl font-medium text-black mb-2 tracking-wide">Create an account</h2>
                    <p class="text-sm text-black mb-8">Enter your details below</p>

                    <form autocomplete="off" action="/users/register" method="post" class="space-y-6">
                        <div>
                            <input id="fullname" class="hk-input" type="text" placeholder="Name" name="fullname" required minlength="3">
                        </div>
                        <div>
                            <input id="reg-email" class="hk-input" type="email" placeholder="Email or Phone Number" name="email" required>
                        </div>
                        <div>
                            <input id="reg-password" class="hk-input" type="password" placeholder="Password" name="password" required>
                        </div>
                        <button class="hk-btn w-full mt-8" type="submit">
                            Create Account
                        </button>
                    </form>

                    <div class="mt-4 flex flex-col gap-4">
                        <button type="button" class="hk-btn-outline w-full flex items-center justify-center gap-3">
                            <i class="ri-google-fill text-xl text-red-500"></i> Sign up with Google
                        </button>
                        <p class="text-center text-sm text-stone-600 mt-4">
                            Already have account?
                            <button onclick="toggleForms()" type="button" class="font-medium text-black underline underline-offset-4 ml-2 hover:text-primary">Log in</button>
                        </p>
                        <a href="/owners/login" class="text-center text-xs font-semibold text-stone-500 hover:text-primary transition mt-2">
                            Go to Admin Login <i class="ri-arrow-right-line"></i>
                        </a>
                    </div>
                </div>

                <!-- Login Section -->
                <div id="login-section" class="<%= (typeof showLogin !== 'undefined' && showLogin) ? 'block' : 'hidden' %> transition-all duration-300">
                    <h2 class="text-3xl font-medium text-black mb-2 tracking-wide">Log in to hk</h2>
                    <p class="text-sm text-black mb-8">Enter your details below</p>

                    <form autocomplete="off" action="/users/login" method="post" class="space-y-6">
                        <div>
                            <input id="login-email" class="hk-input" type="email" placeholder="Email or Phone Number" name="email" required>
                        </div>
                        <div>
                            <input id="login-password" class="hk-input" type="password" placeholder="Password" name="password" required>
                        </div>
                        
                        <div class="flex items-center justify-between mt-8">
                            <button class="hk-btn px-12" type="submit">
                                Log In
                            </button>
                            <a href="#" class="text-sm text-primary hover:underline">Forget Password?</a>
                        </div>
                    </form>

                    <div class="mt-8 text-center text-sm text-stone-600 flex flex-col gap-2">
                        <p>
                            Don't have an account?
                            <button onclick="toggleForms()" type="button" class="font-medium text-black underline underline-offset-4 ml-2 hover:text-primary">Sign up</button>
                        </p>
                        <a href="/owners/login" class="text-center text-xs font-semibold text-stone-500 hover:text-primary transition mt-4">
                            Go to Admin Login <i class="ri-arrow-right-line"></i>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <%- include('./partials/footer') %>

    <script>
        function toggleForms() {
            const registerSection = document.getElementById('register-section');
            const loginSection = document.getElementById('login-section');

            if (registerSection.classList.contains('hidden')) {
                registerSection.classList.remove('hidden');
                loginSection.classList.add('hidden');
            } else {
                registerSection.classList.add('hidden');
                loginSection.classList.remove('hidden');
            }
        }
    </script>
</body>

</html>
