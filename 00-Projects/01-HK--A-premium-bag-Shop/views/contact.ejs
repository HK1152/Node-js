<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>hk - Contact</title>
    <%- include('./partials/theme-head') %>
</head>

<body class="flex flex-col min-h-screen">
    <%- include('./partials/header') %>

    <main class="flex-grow mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 w-full">
        <div class="flex flex-col lg:flex-row gap-8 py-10">
            <!-- Left Side -->
            <div class="w-full lg:w-1/3 border border-stone-200 rounded p-8 flex flex-col gap-8 shadow-sm">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white">
                            <i class="ri-phone-line text-xl"></i>
                        </div>
                        <h3 class="text-xl font-medium">Call To Us</h3>
                    </div>
                    <p class="text-sm text-stone-600 mb-4">We are available 24/7, 7 days a week.</p>
                    <p class="text-sm font-medium">Phone: +8801611112222</p>
                </div>
                <hr class="border-stone-200">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white">
                            <i class="ri-mail-line text-xl"></i>
                        </div>
                        <h3 class="text-xl font-medium">Write To Us</h3>
                    </div>
                    <p class="text-sm text-stone-600 mb-4">Fill out our form and we will contact you within 24 hours.</p>
                    <p class="text-sm font-medium mb-2">Emails: customer@hk.com</p>
                    <p class="text-sm font-medium">Emails: support@hk.com</p>
                </div>
            </div>

            <!-- Right Side Form -->
            <div class="w-full lg:w-2/3 border border-stone-200 rounded p-8 shadow-sm">
                <form class="flex flex-col gap-6">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <input type="text" placeholder="Your Name *" class="hk-input bg-[#F5F5F5] border-none" required>
                        <input type="email" placeholder="Your Email *" class="hk-input bg-[#F5F5F5] border-none" required>
                        <input type="tel" placeholder="Your Phone *" class="hk-input bg-[#F5F5F5] border-none" required>
                    </div>
                    <textarea placeholder="Your Message" class="hk-input bg-[#F5F5F5] border-none min-h-[200px] resize-y"></textarea>
                    <div class="flex justify-end mt-4">
                        <button type="button" class="hk-btn px-10 py-4">Send Message</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <%- include('./partials/footer') %>
</body>

</html>
