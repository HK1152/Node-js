<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart - Scatch Premium</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
        @theme {
            --color-primary: #2b7fff;
            --color-primary-hover: #1a66e6;
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    <%- include('./partials/header') %>

        <main class="flex-grow max-w-7xl mx-auto w-full px-6 lg:px-12 py-12">
            <h2 class="text-3xl font-bold mb-8">Shopping Cart</h2>

            <div class="flex flex-col lg:flex-row gap-10">
                <!-- Cart Items -->
                <div class="w-full lg:w-2/3 flex flex-col gap-6">
                    <% if (user && user.cart && user.cart.length> 0) { %>
                        <% user.cart.forEach((product)=> { %>
                            <div
                                class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col sm:flex-row transition-all hover:shadow-md">
                                <div class="sm:w-1/3 p-6 flex flex-shrink-0 items-center justify-center"
                                    style="background-color: <%= product.bgcolor %>">
                                    <img class="h-32 object-contain"
                                        src="data:image/jpeg;base64, <%= product.image.toString('base64') %>"
                                        alt="<%= product.name %>">
                                </div>
                                <div class="p-6 flex-grow flex flex-col justify-between"
                                    style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>">
                                    <div class="flex justify-between items-start mb-4">
                                        <div>
                                            <h3 class="text-2xl font-bold">
                                                <%= product.name %>
                                            </h3>
                                            <h2 class="text-xl font-medium mt-1">₹ <%= product.price %>
                                            </h2>
                                        </div>
                                        <!-- Optional remove button placeholder -->
                                    </div>

                                    <div class="flex items-center justify-between mt-auto">
                                        <div class="flex items-center gap-4 bg-white/20 rounded-full px-2 py-1">
                                            <button
                                                class="w-8 h-8 rounded-full bg-white text-gray-800 flex items-center justify-center shadow-sm hover:bg-gray-50 transition-colors">
                                                <i class="ri-subtract-line"></i>
                                            </button>
                                            <span class="font-medium">1</span>
                                            <button
                                                class="w-8 h-8 rounded-full bg-white text-gray-800 flex items-center justify-center shadow-sm hover:bg-gray-50 transition-colors">
                                                <i class="ri-add-line"></i>
                                            </button>
                                        </div>
                                        <div class="font-bold text-lg">Net Total: ₹ <%= product.price %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div
                                        class="bg-white rounded-2xl border border-gray-100 p-12 text-center flex flex-col items-center justify-center h-full min-h-[400px]">
                                        <div
                                            class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mb-4">
                                            <i class="ri-shopping-cart-2-line text-3xl text-primary"></i>
                                        </div>
                                        <h3 class="text-2xl font-bold text-gray-900 mb-2">Your cart is empty</h3>
                                        <p class="text-gray-500 mb-6">Looks like you haven't added anything yet.</p>
                                        <a href="/shop"
                                            class="bg-primary hover:bg-primary-hover text-white px-8 py-3 rounded-full font-semibold transition-colors shadow-md shadow-primary/30">Continue
                                            Shopping</a>
                                    </div>
                                    <% } %>
                </div>

                <!-- Order Summary -->
                <div class="w-full lg:w-1/3">
                    <% if (user && user.cart && user.cart.length> 0) { %>
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 sticky top-24">
                            <h3 class="text-xl font-bold mb-6 pb-4 border-b border-gray-100">Order Summary</h3>

                            <div class="space-y-4 text-gray-600 mb-6">
                                <div class="flex justify-between">
                                    <span>Total MRP</span>
                                    <span class="font-medium text-gray-900">₹ <%= totalMRP || 0 %></span>
                                </div>
                                <div class="flex justify-between">
                                    <span>Discount on MRP</span>
                                    <span class="font-medium text-green-600">-₹ <%= totalDiscount || 0 %></span>
                                </div>
                                <div class="flex justify-between">
                                    <span>Platform Fee</span>
                                    <span class="font-medium text-gray-900">₹ 20</span>
                                </div>
                                <div class="flex justify-between">
                                    <span>Shipping Fee</span>
                                    <span class="font-medium text-primary">FREE</span>
                                </div>
                            </div>

                            <div class="border-t border-gray-100 pt-6 mb-6">
                                <div class="flex justify-between items-center">
                                    <span class="text-lg font-bold">Total Amount</span>
                                    <span class="text-2xl font-bold text-gray-900">₹ <%= bill %></span>
                                </div>
                            </div>

                            <button
                                class="w-full py-4 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl shadow-md shadow-primary/30 transition-all transform hover:-translate-y-0.5">
                                Proceed to Checkout
                            </button>
                        </div>
                        <% } %>
                </div>
            </div>
        </main>
        <%- include('./partials/footer') %>
</body>

</html>