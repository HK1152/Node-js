<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HK - Premium Bag Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
        @theme {
            --color-primary: #2b7fff;
            --color-primary-hover: #1a66e6;
        }
    </style>
</head>

<body class="bg-gray-50 text-black font-sans antialiased min-h-screen flex flex-col">
    <%- include('./partials/header') %>

        <% if(error && error.length> 0){ %>
            <div
                class="fixed top-5 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-lg shadow-lg bg-red-500 text-white font-medium animate-bounce">
                <%= error %>
            </div>
            <% } %>

                <main class="flex-grow flex items-center justify-center p-6 lg:p-12">
                    <div
                        class="bg-white rounded-2xl shadow-2xl overflow-hidden w-full max-w-md border border-gray-100 relative">
                        <!-- Decorative element -->
                        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-bl-full pointer-events-none">
                        </div>

                        <!-- Registration Section -->
                        <div id="register-section"
                            class="p-8 sm:p-10 flex flex-col justify-center bg-white relative z-10 transition-all duration-300">
                            <div class="mb-8 text-center text-gray-900">
                                <h2 class="text-3xl font-bold tracking-tight mb-2">Welcome to <span
                                        class="text-primary">HK </span></h2>
                                <p class="text-gray-500 text-sm">Create an account to discover premium bags.</p>
                            </div>

                            <form autocomplete="off" action="/users/register" method="post" class="space-y-5">
                                <div>
                                    <label for="fullname" class="block text-sm font-medium text-gray-700 mb-1">Full
                                        Name</label>
                                    <input id="fullname"
                                        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 outline-none"
                                        type="text" placeholder="John Doe" name="fullname" required minlength="3">
                                </div>
                                <div>
                                    <label for="reg-email" class="block text-sm font-medium text-gray-700 mb-1">Email
                                        Address</label>
                                    <input id="reg-email"
                                        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 outline-none"
                                        type="email" placeholder="you@example.com" name="email" required>
                                </div>
                                <div>
                                    <label for="reg-password"
                                        class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                                    <input id="reg-password"
                                        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 outline-none"
                                        type="password" placeholder="••••••••" name="password" required>
                                </div>
                                <button
                                    class="w-full py-3.5 mt-4 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl shadow-md shadow-primary/30 transition-all duration-200 transform hover:-translate-y-0.5"
                                    type="submit">
                                    Create My Account
                                </button>
                            </form>

                            <p class="mt-8 text-center text-sm text-gray-600">
                                Already have an account?
                                <button onclick="toggleForms()" type="button"
                                    class="text-primary font-semibold hover:underline focus:outline-none">Log
                                    In</button>
                            </p>
                        </div>

                        <!-- Login Section -->
                        <div id="login-section"
                            class="hidden p-8 sm:p-10 flex flex-col justify-center bg-white relative z-10 transition-all duration-300">
                            <div class="mb-8 text-center text-gray-900">
                                <h2 class="text-3xl font-bold tracking-tight mb-2">Welcome Back</h2>
                                <p class="text-gray-500 text-sm">Log in to access your cart and orders.</p>
                            </div>

                            <form autocomplete="off" action="/users/login" method="post" class="space-y-5">
                                <div>
                                    <label for="login-email" class="block text-sm font-medium text-gray-700 mb-1">Email
                                        Address</label>
                                    <input id="login-email"
                                        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 outline-none"
                                        type="email" placeholder="you@example.com" name="email" required>
                                </div>
                                <div>
                                    <label for="login-password"
                                        class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                                    <input id="login-password"
                                        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 outline-none"
                                        type="password" placeholder="••••••••" name="password" required>
                                </div>
                                <button
                                    class="w-full py-3.5 mt-4 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl shadow-md shadow-primary/30 transition-all duration-200 transform hover:-translate-y-0.5"
                                    type="submit">
                                    Log In
                                </button>
                            </form>

                            <p class="mt-8 text-center text-sm text-gray-600">
                                Don't have an account?
                                <button onclick="toggleForms()" type="button"
                                    class="text-primary font-semibold hover:underline focus:outline-none">Create
                                    One</button>
                            </p>
                            <a href="/owners/login"
                                class="text-primary font-semibold hover:underline focus:outline-none">Admin
                                Login</a>
                        </div>
                    </div>
                </main>

                <%- include('./partials/footer') %>

                    <script>
                        function toggleForms() {
                            const registerSection = document.getElementById('register-section');
                            const loginSection = document.getElementById('login-section');

                            if (registerSection.classList.contains('hidden')) {

                                registerSection.classList.remove('hidden');
                                loginSection.classList.add('hidden');
                            } else {
                                registerSection.classList.add('hidden');
                                loginSection.classList.remove('hidden');
                            }
                        }
                    </script>
</body>

</html>