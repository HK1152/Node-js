<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Scatch</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
        @theme {
            --color-primary: #2b7fff;
            --color-primary-hover: #1a66e6;
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    <%- include('./partials/header') %>

        <main class="flex-grow max-w-7xl mx-auto w-full px-6 lg:px-12 py-12 flex flex-col lg:flex-row gap-8">
            <!-- Admin Sidebar -->
            <aside
                class="w-full lg:w-1/4 flex flex-col gap-6 shrink-0 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 h-fit">
                <div class="pb-4 border-b border-gray-100">
                    <h3 class="text-sm font-semibold tracking-wider text-gray-400 uppercase">Dashboard</h3>
                </div>
                <div class="flex flex-col gap-3">
                    <a class="text-primary font-medium transition-colors flex items-center gap-2"
                        href="/owners/admin"><i class="ri-box-3-line"></i> All Products</a>
                    <a class="text-gray-600 hover:text-primary font-medium transition-colors flex items-center gap-2"
                        href="/owners/products/create"><i class="ri-add-circle-line"></i> Create New Product</a>
                </div>
            </aside>

            <!-- Main Content -->
            <section class="w-full lg:w-3/4">
                <div class="bg-white p-8 sm:p-10 rounded-2xl shadow-sm border border-gray-100">
                    <div class="flex items-center justify-between mb-8 border-b border-gray-100 pb-4">
                        <div>
                            <h2 class="text-2xl font-bold tracking-tight">Inventory</h2>
                            <p class="text-gray-500 text-sm mt-1">Manage your active products</p>
                        </div>
                        <a href="#"
                            class="text-red-500 hover:text-red-600 font-medium text-sm flex items-center gap-1 bg-red-50 hover:bg-red-100 px-4 py-2 rounded-lg transition-colors">
                            <i class="ri-delete-bin-line"></i> Delete All
                        </a>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        <% if (products && products.length> 0) { %>
                            <% products.forEach(function(product) { %>
                                <div
                                    class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden relative group flex flex-col">
                                    <div class="w-full h-48 flex items-center justify-center p-4 relative"
                                        style="background-color: <%= product.bgcolor %>">
                                        <img class="h-full object-contain group-hover:scale-110 transition-transform duration-500"
                                            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                            alt="<%= product.name %>">
                                    </div>
                                    <div class="p-4 flex justify-between items-center bg-white border-t border-gray-50 flex-grow"
                                        style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>">
                                        <div>
                                            <h3 class="font-bold truncate">
                                                <%= product.name %>
                                            </h3>
                                            <h4 class="text-sm">₹ <%= product.price %>
                                            </h4>
                                        </div>
                                        <button
                                            class="w-8 h-8 flex items-center justify-center rounded-full bg-red-50 text-red-500 hover:bg-red-500 hover:text-white transition-colors shrink-0 shadow-sm border border-red-100">
                                            <i class="ri-delete-bin-3-line"></i>
                                        </button>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } %>
                                        <!-- Sample Add more -->
                                        <a href="/owners/products/create"
                                            class="bg-gray-50 border-2 border-dashed border-gray-200 rounded-xl flex flex-col items-center justify-center h-full min-h-[16rem] hover:bg-gray-100 hover:border-primary/50 group transition-colors cursor-pointer">
                                            <div
                                                class="w-12 h-12 bg-white rounded-full shadow-sm flex items-center justify-center text-gray-400 group-hover:text-primary mb-3 transition-colors">
                                                <i class="ri-add-line text-xl"></i>
                                            </div>
                                            <span
                                                class="text-gray-500 font-medium group-hover:text-primary transition-colors">Add
                                                Product</span>
                                        </a>
                    </div>
                </div>
            </section>
        </main>
        <%- include('./partials/footer') %>
</body>

</html>