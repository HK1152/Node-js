<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Product - Scatch Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
        @theme {
            --color-primary: #2b7fff;
            --color-primary-hover: #1a66e6;
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    <%- include('./partials/header') %>

        <% if (typeof success !=='undefined' && success && success.length> 0) { %>
            <div
                class="fixed top-5 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-full shadow-lg bg-green-500 text-white font-medium animate-bounce">
                <%= success %>
            </div>
            <% } %>

                <main class="flex-grow max-w-7xl mx-auto w-full px-6 lg:px-12 py-12 flex flex-col lg:flex-row gap-8">
                    <!-- Admin Sidebar -->
                    <aside
                        class="w-full lg:w-1/4 flex flex-col gap-6 shrink-0 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 h-fit">
                        <div class="pb-4 border-b border-gray-100">
                            <h3 class="text-sm font-semibold tracking-wider text-gray-400 uppercase">Dashboard</h3>
                        </div>
                        <div class="flex flex-col gap-3">
                            <a class="text-gray-600 hover:text-primary font-medium transition-colors flex items-center gap-2"
                                href="/owners/admin"><i class="ri-box-3-line"></i> All Products</a>
                            <a class="text-primary font-medium transition-colors flex items-center gap-2"
                                href="/owners/products/create"><i class="ri-add-circle-line"></i> Create New Product</a>
                        </div>
                    </aside>

                    <!-- Main Content -->
                    <section class="w-full lg:w-3/4">
                        <div class="bg-white p-8 sm:p-10 rounded-2xl shadow-sm border border-gray-100">
                            <div class="mb-8 border-b border-gray-100 pb-4">
                                <h2 class="text-2xl font-bold tracking-tight">Create New Product</h2>
                                <p class="text-gray-500 text-sm mt-1">Add a new premium bag to your inventory.</p>
                            </div>

                            <form autocomplete="off" action="/products/create" method="post"
                                enctype="multipart/form-data" class="space-y-8">
                                <!-- Product Details Section -->
                                <div class="p-6 bg-gray-50 rounded-xl border border-gray-100 space-y-5">
                                    <h3 class="text-lg font-bold text-gray-900 border-b border-gray-200 pb-3">Product
                                        Information</h3>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Product
                                            Image</label>
                                        <input name="image" type="file" required
                                            class="w-full file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-primary file:text-white hover:file:bg-primary-hover file:transition-colors bg-white border border-gray-200 rounded-xl px-3 py-2 outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all">
                                    </div>

                                    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Product
                                                Name</label>
                                            <input name="name" type="text" placeholder="e.g. Classic Tote" required
                                                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all outline-none">
                                        </div>
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Price
                                                (₹)</label>
                                            <input name="price" type="number" placeholder="2500" required
                                                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all outline-none">
                                        </div>
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Discount Price
                                                (₹)</label>
                                            <input name="discount" type="number" placeholder="200"
                                                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all outline-none">
                                        </div>
                                    </div>
                                </div>

                                <!-- Panel Details Section -->
                                <div class="p-6 bg-gray-50 rounded-xl border border-gray-100 space-y-5">
                                    <h3 class="text-lg font-bold text-gray-900 border-b border-gray-200 pb-3">Styling
                                        Configuration</h3>
                                    <p class="text-xs text-gray-500 mb-4">Use hex codes (e.g. #ffffff) for the product
                                        card colors.</p>

                                    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Background
                                                Color</label>
                                            <input name="bgcolor" type="text" placeholder="#f0f0f0" required
                                                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all outline-none">
                                        </div>
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Panel
                                                Color</label>
                                            <input name="panelcolor" type="text" placeholder="#ffffff" required
                                                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all outline-none">
                                        </div>
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Text
                                                Color</label>
                                            <input name="textcolor" type="text" placeholder="#000000" required
                                                class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all outline-none">
                                        </div>
                                    </div>
                                </div>

                                <div class="pt-2">
                                    <button type="submit"
                                        class="w-full md:w-auto px-8 py-3.5 bg-primary hover:bg-primary-hover text-white font-semibold rounded-xl shadow-md shadow-primary/30 transition-all transform hover:-translate-y-0.5 flex justify-center items-center gap-2">
                                        <i class="ri-check-line"></i> Create Product
                                    </button>
                                </div>
                            </form>
                        </div>
                    </section>
                </main>
                <%- include('./partials/footer') %>
</body>

</html>