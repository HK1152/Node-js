<header class="w-full bg-white border-b border-gray-100 sticky top-0 z-50">
    <nav class="max-w-7xl mx-auto px-6 lg:px-12 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold tracking-tighter text-gray-900 hover:text-primary transition-colors">
            Hare Krishna<span class="text-primary">.</span>
        </a>

        <% if (typeof owner !=='undefined' && owner) { %>
            <div class="flex items-center gap-6 text-sm font-medium">
                <a href="/owners/admin"
                    class="text-gray-600 hover:text-primary transition-colors flex items-center gap-1">
                    <i class="ri-dashboard-line text-lg"></i> Dashboard
                </a>
                <a href="/owners/products/create"
                    class="text-gray-600 hover:text-primary transition-colors flex items-center gap-1">
                    <i class="ri-add-circle-line text-lg"></i> Product
                </a>
                <a href="/owners/logout"
                    class="ml-2 px-5 py-2 text-red-600 bg-red-50 rounded-full hover:bg-red-100 transition-colors">Logout</a>
            </div>
            <% } else if (typeof user !=='undefined' || (typeof loggedin !=='undefined' && loggedin)) { %>
                <div class="flex items-center gap-6 text-sm font-medium">
                    <a href="/shop" class="text-gray-600 hover:text-primary transition-colors">Shop</a>
                    <a href="/cart" class="text-gray-600 hover:text-primary transition-colors flex items-center gap-1">
                        <i class="ri-shopping-bag-3-line text-lg"></i> Cart
                    </a>
                    <a href="logout"
                        class="ml-2 px-5 py-2 text-red-600 bg-red-50 rounded-full hover:bg-red-100 transition-colors">Logout</a>
                </div>
                <% } else { %>
                    <div class="flex items-center gap-4 text-sm font-medium">
                        <a href="/" class="text-gray-600 hover:text-primary transition-colors flex items-center gap-1">
                            <i class="ri-user-line text-lg"></i> User
                        </a>
                        <a href="/owners/login"
                            class="px-5 py-2 bg-gray-900 text-white rounded-full hover:bg-black transition-colors shadow-sm flex items-center gap-1">
                            <i class="ri-store-2-line text-lg"></i> Seller
                        </a>
                    </div>
                    <% } %>
    </nav>
</header>