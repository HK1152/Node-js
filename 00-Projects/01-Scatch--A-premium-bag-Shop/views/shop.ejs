<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shop - Scatch Premium</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
        @theme {
            --color-primary: #2b7fff;
            --color-primary-hover: #1a66e6;
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    <%- include('./partials/header') %>

        <% if (typeof success !=='undefined' && success && success.length> 0) { %>
            <div
                class="fixed top-5 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-full shadow-lg bg-green-500 text-white font-medium animate-bounce">
                <%= success %>
            </div>
            <% } %>

                <main class="flex-grow max-w-7xl mx-auto w-full px-6 lg:px-12 py-12 flex flex-col lg:flex-row gap-8">
                    <!-- Sidebar -->
                    <aside class="w-full lg:w-1/4 flex flex-col gap-8 shrink-0">
                        <div>
                            <h3 class="text-sm font-semibold tracking-wider text-gray-400 uppercase mb-4">Sort By</h3>
                            <form action="/shop">
                                <div class="relative">
                                    <select
                                        class="w-full appearance-none bg-white border border-gray-200 text-gray-700 py-3 px-4 pr-8 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all cursor-pointer"
                                        name="sortby" id="">
                                        <option value="popular">Popular</option>
                                        <option value="newest">Newest</option>
                                    </select>
                                    <div
                                        class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
                                        <i class="ri-arrow-down-s-line"></i>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <div>
                            <h3 class="text-sm font-semibold tracking-wider text-gray-400 uppercase mb-4">Categories
                            </h3>
                            <div class="flex flex-col gap-3">
                                <a class="text-gray-600 hover:text-primary font-medium transition-colors" href="">New
                                    Collection</a>
                                <a class="text-primary font-medium transition-colors" href="">All Products</a>
                                <a class="text-gray-600 hover:text-primary font-medium transition-colors"
                                    href="">Discounted</a>
                            </div>
                        </div>

                        <div>
                            <h3 class="text-sm font-semibold tracking-wider text-gray-400 uppercase mb-4">Filter By</h3>
                            <div class="flex flex-col gap-3">
                                <a class="text-gray-600 hover:text-primary font-medium transition-colors"
                                    href="">Availability</a>
                                <a class="text-gray-600 hover:text-primary font-medium transition-colors"
                                    href="">Discount</a>
                            </div>
                        </div>
                    </aside>

                    <!-- Product Grid -->
                    <section class="w-full lg:w-3/4">
                        <div class="flex items-center justify-between mb-8">
                            <h2 class="text-3xl font-bold">All Products</h2>
                            <span class="text-gray-500 text-sm">
                                <%= products ? products.length : 0 %> results
                            </span>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                            <% if (products && products.length) { %>
                                <% products.forEach(function(product){ %>
                                    <div
                                        class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 group flex flex-col">
                                        <div class="w-full h-64 flex items-center justify-center relative p-6"
                                            style="background-color: <%= product.bgcolor %>">
                                            <img class="h-full object-contain group-hover:scale-110 transition-transform duration-500"
                                                src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                                alt="<%= product.name %>">
                                        </div>
                                        <div class="p-5 flex-grow flex flex-col justify-between"
                                            style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>">
                                            <div class="mb-4">
                                                <h3 class="text-lg font-bold truncate">
                                                    <%= product.name %>
                                                </h3>
                                                <h4 class="text-xl font-medium mt-1">₹ <%= product.price %>
                                                </h4>
                                            </div>
                                            <a class="w-full py-2.5 flex items-center justify-center gap-2 rounded-xl bg-primary text-white font-semibold hover:bg-primary-hover transition-colors"
                                                href="/add-to-cart/<%= product._id %>">
                                                <i class="ri-shopping-bag-add-line"></i> Add to Cart
                                            </a>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="col-span-full py-16 text-center text-gray-500">
                                                <div
                                                    class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
                                                    <i class="ri-shopping-bag-3-line text-2xl text-gray-400"></i>
                                                </div>
                                                <h3 class="text-xl font-medium text-gray-900 mb-1">No products found
                                                </h3>
                                                <p>It looks like we're out of stock right now.</p>
                                            </div>
                                            <% } %>
                        </div>
                    </section>
                </main>

                <%- include('./partials/footer') %>
</body>

</html>